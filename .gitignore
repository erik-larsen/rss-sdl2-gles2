# Build outputs
logs/
bin-*/
*.o
*.a
*.wasm
*.js
*.html

# but keep source HTML/JS shells and the gallery template
!libs/librs/shell.html
!scripts/gallery.html
!.github/**/*.yml

# gl4es build trees and output libs
libs/gl4es/build/
libs/gl4es/build-native/
